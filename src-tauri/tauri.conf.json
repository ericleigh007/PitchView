{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PitchView",
  "version": "0.1.0",
  "identifier": "com.pitchview.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1430",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": {
        "default-src": ["'self'", "asset:", "http://asset.localhost"],
        "img-src": ["'self'", "data:", "blob:", "asset:", "http://asset.localhost"],
        "media-src": ["'self'", "data:", "blob:", "asset:", "http://asset.localhost"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost"]
      }
    },
    "windows": [
      {
        "title": "PitchView",
        "width": 1680,
        "height": 1120,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}